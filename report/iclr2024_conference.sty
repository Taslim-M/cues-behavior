%%%% ICLR 2024 conference style (faithful reconstruction) %%%%
%% Self-contained so the project compiles on Overleaf out of the box.
%% If you prefer the OFFICIAL file, create a project from Overleaf's
%% "ICLR 2024" template and overwrite this file with theirs; main.tex
%% is written to work with either (it only relies on \iclrfinalcopy,
%% the title/author/abstract macros, and \month/\year defaults).
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{iclr2024_conference}[2024/01/01 ICLR 2024 conference style (reconstruction)]

\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{times}
\RequirePackage{ifthen}
\RequirePackage{titlesec}

% --- Page geometry (matches the ICLR/NeurIPS-derived block) ---------------
\geometry{letterpaper, top=1in, bottom=1in, left=1.5in, right=1.5in,
          headheight=12pt, headsep=20pt}

% --- Final-copy switch (author names shown only when \iclrfinalcopy) -------
\newboolean{iclrfinal}
\setboolean{iclrfinal}{false}
\newcommand{\iclrfinalcopy}{\setboolean{iclrfinal}{true}}

% --- Line spacing / paragraph -------------------------------------------
\setlength{\parindent}{0pt}
\setlength{\parskip}{6pt plus 2pt minus 1pt}
\renewcommand{\baselinestretch}{1.0}

% --- Author separators used in ICLR author blocks ------------------------
\newcommand{\And}{\hspace{2em}}
\newcommand{\AND}{\\[2mm]}

% --- Section formatting (bold, sans-serif-ish sizing per ICLR) -----------
\titleformat{\section}{\large\bfseries}{\thesection}{0.8em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{0.8em}{}
\titleformat{\subsubsection}{\normalsize\bfseries}{\thesubsubsection}{0.8em}{}
\titlespacing*{\section}{0pt}{12pt plus 3pt}{6pt}
\titlespacing*{\subsection}{0pt}{10pt plus 2pt}{4pt}

% --- Title block ---------------------------------------------------------
\renewcommand{\@maketitle}{%
  \newpage
  \null
  \vskip 1em%
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 1.2em%
    {\normalsize
      \ifthenelse{\boolean{iclrfinal}}{\@author}{%
        Anonymous authors\\Paper under double-blind review}\par}%
  \end{center}%
  \vskip 1em%
}

% --- Abstract centered with rules (ICLR look) ----------------------------
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5em}%
  \begin{quote}\small
}{%
  \end{quote}%
  \vspace{0.5em}%
}

% --- Running header ------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\fancyhead[C]{\small Under review as a conference paper at ICLR 2024}
\fancyfoot[C]{\small\thepage}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}

% ICLR uses numbered sections without the word "Section"
\setcounter{secnumdepth}{3}

\endinput
